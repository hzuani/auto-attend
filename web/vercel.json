{
  "rewrites": [
    { "source": "/sign", "destination": "/sign/index.html" },
    { "source": "/teacher", "destination": "/teacher/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
